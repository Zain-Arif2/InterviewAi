"# App\nNEXT_PUBLIC_APP_URL=http://localhost:3000\nNEXTAUTH_SECRET=your-secret-key-here-change-in-production\nNEXTAUTH_URL=http://localhost:3000\n\n# MongoDB Atlas\nMONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/interviewai\n\n# Upstash Redis\nUPSTASH_REDIS_REST_URL=https://your-redis.upstash.io\nUPSTASH_REDIS_REST_TOKEN=your-redis-token\n\n# Resend (Email)\nRESEND_API_KEY=re_xxxxxxxxxxxx\nEMAIL_FROM=noreply@interviewai.com\n\n# Stripe\nSTRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx\nSTRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx\nNEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx\nNEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxx\n\n# OpenRouter (AI)\nOPENROUTER_API_KEY=sk-or-xxxxxxxxxxxx\n\n# OpenAI (Pro voice features)\nOPENAI_API_KEY=sk-xxxxxxxxxxxx\n\n# ElevenLabs (Pro TTS alternative)\nELEVENLABS_API_KEY=xxxxxxxxxxxx\n\n# Admin\nADMIN_EMAIL=admin@interviewai.com\n"